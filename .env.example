# ============================================================
# EnergyManager — Umgebungsvariablen
# ============================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# ============================================================

# --- Datenbank ---
# SQLite (Entwicklung, kein Docker nötig):
#   DATABASE_URL=sqlite+aiosqlite:///./energiemanager.db
# TimescaleDB (Produktion, via Docker):
DATABASE_URL=postgresql+asyncpg://energiemanager:secret@localhost:5432/energiemanager
TIMESCALE_ENABLED=true

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Wetter ---
# Open-Meteo wird verwendet (kostenlos, kein API-Key nötig).
# Standort-Koordinaten (Default: Mitte Deutschlands)
LATITUDE=51.1657
LONGITUDE=10.4515

# --- Sicherheit ---
# WICHTIG: Beide Werte in Produktion ändern!
SECRET_KEY=change-me-in-production
API_KEY=change-me-in-production

# --- ML ---
ML_MODEL_DIR=./ml_models
ML_RETRAIN_INTERVAL_HOURS=168

# --- Logging ---
LOG_LEVEL=INFO

# --- Ports (optional, Default-Werte) ---
# EM_BACKEND_PORT=8000
# EM_FRONTEND_PORT=8080
# GRAFANA_PORT=3001
