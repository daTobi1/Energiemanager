{
  "id": "lambda_eu_l",
  "manufacturer": "Lambda",
  "model": "Eureka EU-L (EU08L–EU20L)",
  "category": "heat_pump",
  "protocol": "modbus_tcp",
  "version": "1.0",
  "description": "Lambda Eureka Luft-Wasser-Waermepumpe. Unterstuetzt bis zu 3 WP, 5 Boiler, 5 Buffer, 2 Solar, 12 Heizkreise. Auch fuer Zewotherm-OEM-Varianten.",
  "defaults": {
    "port": 502,
    "unitId": 1,
    "timeout": 60,
    "pollingIntervalSeconds": 30
  },
  "register_groups": [
    {
      "name": "ambient",
      "base_address": 0,
      "source": "outdoor",
      "registers": [
        { "offset": 0, "metric": "ambient_error", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 1, "metric": "ambient_state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 2, "metric": "temperature_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 3, "metric": "temp_1h_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 4, "metric": "temp_calc_c", "unit": "°C", "scale": 0.1, "data_type": "int16" }
      ]
    },
    {
      "name": "emanager",
      "base_address": 100,
      "source": "emanager",
      "registers": [
        { "offset": 0, "metric": "error", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 1, "metric": "state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 2, "metric": "pv_surplus_w", "unit": "W", "scale": 1, "data_type": "int16", "writable": true },
        { "offset": 3, "metric": "total_power_w", "unit": "W", "scale": 1, "data_type": "int16" },
        { "offset": 4, "metric": "power_setpoint_w", "unit": "W", "scale": 1, "data_type": "int16" }
      ]
    },
    {
      "name": "heat_pump",
      "base_address": 1000,
      "source": "heat_pump",
      "source_template": "hp_{instance}",
      "repeatable": true,
      "max_instances": 3,
      "instance_offset": 100,
      "probe_offset": 3,
      "registers": [
        { "offset": 0, "metric": "error_state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 1, "metric": "error_number", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 2, "metric": "compressor_state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 3, "metric": "operating_state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 4, "metric": "flow_temperature_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 5, "metric": "return_temperature_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 6, "metric": "volume_flow_lh", "unit": "l/h", "scale": 1, "data_type": "int16" },
        { "offset": 7, "metric": "source_inlet_temp_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 8, "metric": "source_outlet_temp_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 9, "metric": "source_volume_flow_lmin", "unit": "l/min", "scale": 0.01, "data_type": "int16" },
        { "offset": 10, "metric": "compressor_rating_pct", "unit": "%", "scale": 0.01, "data_type": "uint16" },
        { "offset": 11, "metric": "heat_kw", "unit": "kW", "scale": 0.1, "data_type": "int16" },
        { "offset": 12, "metric": "power_w", "unit": "W", "scale": 1, "data_type": "int16" },
        { "offset": 13, "metric": "cop", "unit": "", "scale": 0.01, "data_type": "int16" },
        { "offset": 15, "metric": "request_type", "unit": "", "scale": 1, "data_type": "int16", "writable": true },
        { "offset": 16, "metric": "requested_flow_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true },
        { "offset": 17, "metric": "requested_return_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true },
        { "offset": 19, "metric": "second_stage_state", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 20, "metric": "energy_consumed_wh", "unit": "Wh", "scale": 1, "data_type": "int32" },
        { "offset": 22, "metric": "energy_produced_wh", "unit": "Wh", "scale": 1, "data_type": "int32" },
        { "offset": 25, "metric": "vda_rating_pct", "unit": "%", "scale": 0.01, "data_type": "uint16" },
        { "offset": 26, "metric": "hot_gas_temp_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 29, "metric": "condensation_temp_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 30, "metric": "evaporation_temp_c", "unit": "°C", "scale": 0.01, "data_type": "int16" },
        { "offset": 31, "metric": "eqm_rating_pct", "unit": "%", "scale": 0.01, "data_type": "uint16" }
      ]
    },
    {
      "name": "boiler",
      "base_address": 2000,
      "source": "boiler",
      "source_template": "boiler_{instance}",
      "repeatable": true,
      "max_instances": 5,
      "instance_offset": 100,
      "probe_offset": 1,
      "registers": [
        { "offset": 0, "metric": "error", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 1, "metric": "state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 2, "metric": "temp_high_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 3, "metric": "temp_low_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 4, "metric": "circ_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 5, "metric": "circ_pump", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 50, "metric": "target_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true }
      ]
    },
    {
      "name": "buffer",
      "base_address": 3000,
      "source": "buffer",
      "source_template": "buffer_{instance}",
      "repeatable": true,
      "max_instances": 5,
      "instance_offset": 100,
      "probe_offset": 1,
      "registers": [
        { "offset": 0, "metric": "error", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 1, "metric": "state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 2, "metric": "temp_high_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 3, "metric": "temp_low_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 4, "metric": "temp_setpoint_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true },
        { "offset": 6, "metric": "flow_setpoint_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 9, "metric": "requested_kw", "unit": "kW", "scale": 0.1, "data_type": "int16" },
        { "offset": 50, "metric": "max_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true }
      ]
    },
    {
      "name": "solar",
      "base_address": 4000,
      "source": "solar_thermal",
      "source_template": "solar_{instance}",
      "repeatable": true,
      "max_instances": 2,
      "instance_offset": 100,
      "probe_offset": 1,
      "registers": [
        { "offset": 0, "metric": "error", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 1, "metric": "state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 2, "metric": "collector_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 3, "metric": "storage_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 4, "metric": "power_kw", "unit": "kW", "scale": 0.1, "data_type": "int16" },
        { "offset": 5, "metric": "energy_kwh", "unit": "kWh", "scale": 1, "data_type": "int32" }
      ]
    },
    {
      "name": "heating_circuit",
      "base_address": 5000,
      "source": "heating_circuit",
      "source_template": "hc_{instance}",
      "repeatable": true,
      "max_instances": 12,
      "instance_offset": 100,
      "probe_offset": 1,
      "registers": [
        { "offset": 0, "metric": "error", "unit": "", "scale": 1, "data_type": "int16" },
        { "offset": 1, "metric": "state", "unit": "", "scale": 1, "data_type": "uint16" },
        { "offset": 2, "metric": "flow_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 3, "metric": "return_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 4, "metric": "room_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true },
        { "offset": 5, "metric": "set_flow_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true },
        { "offset": 6, "metric": "mode", "unit": "", "scale": 1, "data_type": "int16", "writable": true },
        { "offset": 7, "metric": "flow_setpoint_c", "unit": "°C", "scale": 0.1, "data_type": "int16" },
        { "offset": 50, "metric": "flow_offset_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true },
        { "offset": 51, "metric": "target_room_temp_c", "unit": "°C", "scale": 0.1, "data_type": "int16", "writable": true }
      ]
    }
  ],
  "write_map": {
    "pv_surplus_w": { "address": 102, "scale": 1.0, "data_type": "int16" },
    "boiler_target_temp_c": { "address": 2050, "scale": 10.0, "data_type": "int16" },
    "hp_requested_flow_temp_c": { "address": 1016, "scale": 10.0, "data_type": "int16" },
    "hp_requested_return_temp_c": { "address": 1017, "scale": 10.0, "data_type": "int16" },
    "hc_1_target_room_temp_c": { "address": 5051, "scale": 10.0, "data_type": "int16" },
    "hc_2_target_room_temp_c": { "address": 5151, "scale": 10.0, "data_type": "int16" },
    "hc_3_target_room_temp_c": { "address": 5251, "scale": 10.0, "data_type": "int16" },
    "hc_1_flow_offset_c": { "address": 5050, "scale": 10.0, "data_type": "int16" },
    "hc_2_flow_offset_c": { "address": 5150, "scale": 10.0, "data_type": "int16" },
    "hc_3_flow_offset_c": { "address": 5250, "scale": 10.0, "data_type": "int16" },
    "hc_1_flow_temp_c": { "address": 5005, "scale": 10.0, "data_type": "int16" },
    "hc_2_flow_temp_c": { "address": 5105, "scale": 10.0, "data_type": "int16" },
    "hc_3_flow_temp_c": { "address": 5205, "scale": 10.0, "data_type": "int16" }
  },
  "setpoint_routing": {
    "hp_thermal_kw": { "target": "pv_surplus_w", "transform": "value * 1000" },
    "flow_temp_c": { "target": "hp_requested_flow_temp_c" }
  },
  "computed_values": [
    { "metric": "power_kw", "source_metric": "power_w", "transform": "value / 1000" },
    { "metric": "cop_calculated", "source_metric": "cop", "transform": "value" }
  ],
  "state_maps": {
    "operating_state": {
      "0": "Standby", "1": "Heizen", "2": "Warmwasser", "3": "Kuehlen",
      "4": "Zirkulation", "5": "Abtauen", "6": "Aus", "7": "Frostschutz",
      "10": "Sommerbetrieb", "11": "Urlaub", "12": "Fehler"
    }
  }
}
