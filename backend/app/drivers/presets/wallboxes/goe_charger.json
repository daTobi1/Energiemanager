{
  "id": "goe_charger",
  "manufacturer": "go-e",
  "model": "go-eCharger Gemini / HOME",
  "category": "wallbox",
  "protocol": "http_rest",
  "version": "1.0",
  "description": "go-eCharger Gemini und HOME Wallbox ueber HTTP API v2. Unterstuetzt Laden, Phasenumschaltung und PV-Ueberschussladen.",
  "defaults": {
    "port": 80,
    "timeout": 10,
    "pollingIntervalSeconds": 5
  },
  "endpoints": [
    {
      "name": "status",
      "path": "/api/status",
      "method": "GET",
      "source": "wallbox",
      "value_mappings": [
        { "metric": "car_status", "json_path": "$.car", "unit": "", "scale": 1 },
        { "metric": "power_w", "json_path": "$.nrg[11]", "unit": "W", "scale": 10 },
        { "metric": "energy_wh", "json_path": "$.wh", "unit": "Wh", "scale": 1 },
        { "metric": "current_limit_a", "json_path": "$.amp", "unit": "A", "scale": 1 },
        { "metric": "phases_active", "json_path": "$.pha", "unit": "", "scale": 1 },
        { "metric": "voltage_l1_v", "json_path": "$.nrg[0]", "unit": "V", "scale": 1 },
        { "metric": "voltage_l2_v", "json_path": "$.nrg[1]", "unit": "V", "scale": 1 },
        { "metric": "voltage_l3_v", "json_path": "$.nrg[2]", "unit": "V", "scale": 1 },
        { "metric": "current_l1_a", "json_path": "$.nrg[4]", "unit": "A", "scale": 0.1 },
        { "metric": "current_l2_a", "json_path": "$.nrg[5]", "unit": "A", "scale": 0.1 },
        { "metric": "current_l3_a", "json_path": "$.nrg[6]", "unit": "A", "scale": 0.1 },
        { "metric": "temperature_c", "json_path": "$.tmp", "unit": "°C", "scale": 1 },
        { "metric": "total_energy_kwh", "json_path": "$.eto", "unit": "kWh", "scale": 0.1 }
      ]
    }
  ],
  "write_map": {
    "current_limit_a": { "address": 0, "scale": 1.0, "data_type": "int16", "http_path": "/api/set?amp={value}" },
    "allow_charging": { "address": 0, "scale": 1.0, "data_type": "int16", "http_path": "/api/set?alw={value}" }
  },
  "setpoint_routing": {
    "ev_charge_current_a": { "target": "current_limit_a", "transform": "value" }
  },
  "computed_values": [
    { "metric": "power_kw", "source_metric": "power_w", "transform": "value / 1000" }
  ],
  "state_maps": {
    "car_status": {
      "1": "Bereit (kein Auto)",
      "2": "Auto angeschlossen",
      "3": "Laedt",
      "4": "Lueftung aktiv"
    }
  }
}
