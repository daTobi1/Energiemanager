{
  "id": "sdm630_modbus",
  "manufacturer": "Eastron",
  "model": "SDM630-Modbus V2",
  "category": "meter",
  "protocol": "modbus_tcp",
  "version": "1.0",
  "description": "Eastron SDM630 Drehstromzaehler (Modbus RTU ueber TCP Gateway). 3-Phasen Energie-, Leistungs- und Qualitaetsmessung.",
  "defaults": {
    "port": 502,
    "unitId": 1,
    "timeout": 10,
    "pollingIntervalSeconds": 5
  },
  "register_groups": [
    {
      "name": "power",
      "base_address": 0,
      "source": "meter",
      "registers": [
        { "offset": 0, "metric": "voltage_l1_v", "unit": "V", "scale": 1, "data_type": "float32" },
        { "offset": 2, "metric": "voltage_l2_v", "unit": "V", "scale": 1, "data_type": "float32" },
        { "offset": 4, "metric": "voltage_l3_v", "unit": "V", "scale": 1, "data_type": "float32" },
        { "offset": 6, "metric": "current_l1_a", "unit": "A", "scale": 1, "data_type": "float32" },
        { "offset": 8, "metric": "current_l2_a", "unit": "A", "scale": 1, "data_type": "float32" },
        { "offset": 10, "metric": "current_l3_a", "unit": "A", "scale": 1, "data_type": "float32" },
        { "offset": 12, "metric": "power_l1_w", "unit": "W", "scale": 1, "data_type": "float32" },
        { "offset": 14, "metric": "power_l2_w", "unit": "W", "scale": 1, "data_type": "float32" },
        { "offset": 16, "metric": "power_l3_w", "unit": "W", "scale": 1, "data_type": "float32" },
        { "offset": 52, "metric": "total_power_w", "unit": "W", "scale": 1, "data_type": "float32" },
        { "offset": 54, "metric": "total_var", "unit": "var", "scale": 1, "data_type": "float32" },
        { "offset": 56, "metric": "total_va", "unit": "VA", "scale": 1, "data_type": "float32" },
        { "offset": 62, "metric": "power_factor", "unit": "", "scale": 1, "data_type": "float32" },
        { "offset": 70, "metric": "frequency_hz", "unit": "Hz", "scale": 1, "data_type": "float32" }
      ]
    },
    {
      "name": "energy",
      "base_address": 72,
      "source": "meter",
      "registers": [
        { "offset": 0, "metric": "import_energy_kwh", "unit": "kWh", "scale": 1, "data_type": "float32" },
        { "offset": 2, "metric": "export_energy_kwh", "unit": "kWh", "scale": 1, "data_type": "float32" },
        { "offset": 270, "metric": "total_energy_kwh", "unit": "kWh", "scale": 1, "data_type": "float32" }
      ]
    }
  ],
  "write_map": {},
  "setpoint_routing": {},
  "computed_values": [
    { "metric": "power_kw", "source_metric": "total_power_w", "transform": "value / 1000" }
  ],
  "state_maps": {}
}
